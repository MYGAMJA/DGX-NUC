<!-- ============================================================
  Hylion v7  —  BHL biped 기반 + SO-ARM 팔 질량 추가
  IsaacLab policy sim-to-sim 검증용

  BHL biped와 동일한 kinematics / collision geometry 사용.
  hylion_v6.xml에서 cylinder geom 부재로 contact dynamics 차이 발생 →
  BHL biped MJCF를 직접 베이스로 사용해 해결.

  변경 사항 (BHL biped 대비):
    - compiler angle="radian" 추가 (BHL 원본과 동일, joint range 라디안 해석 필수!)
    - base inertial mass: 3.16 → 4.83 kg (Hylion 학습 기준)
    - soarm_left / soarm_right 추가 (mass=3.44 × 2 = 6.88 kg)
    - 총 질량: 19.89 kg (학습 목표 정확히 일치, play_mujoco.py 보정 0)
    - physics options: timestep=0.005 (play_mujoco.py에서 덮어씀)
    - mesh 경로: 절대경로 사용

  obs 45-dim / action 12-dim 구성은 hylion_v6.xml과 동일.
============================================================ -->

<mujoco model="hylion_v7">

  <!-- BHL biped 원본과 동일: 모든 각도를 라디안으로 해석 -->
  <compiler angle="radian" autolimits="true"/>

  <!-- ── 시뮬레이션 옵션 ──────────────────────────────────────── -->
  <option
    timestep="0.005"
    gravity="0 0 -9.81"
    integrator="implicitfast"
  />

  <!-- ── BHL biped default class ───────────────────────────────── -->
  <default>
    <default class="berkeley-humanoid-lite">
      <joint frictionloss="0.1" armature="0.005"/>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom group="3"/>
      </default>
    </default>
    <!-- 지면: contype=0 conaffinity=1 → 로봇하고만 충돌 -->
    <geom friction="0.8 0.1 0.1"/>
  </default>

  <!-- ── 자산: BHL biped 메시 절대경로 ──────────────────────────── -->
  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.4 0.6 0.8" rgb2="0 0 0" width="512" height="512"/>
    <texture name="texplane" type="2d" builtin="checker"
             rgb1="0.2 0.2 0.2" rgb2="0.3 0.3 0.3" width="512" height="512"/>
    <material name="matplane" texture="texplane" texrepeat="4 4" reflectance="0.2"/>

    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/base_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/imu_2_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_left_hip_roll_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_left_hip_yaw_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_left_hip_pitch_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_left_knee_pitch_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_left_ankle_pitch_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_left_ankle_roll_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_right_hip_roll_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_right_hip_yaw_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_right_hip_pitch_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_right_knee_pitch_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_right_ankle_pitch_visual.stl"/>
    <mesh file="/home/laba/Berkeley-Humanoid-Lite/source/berkeley_humanoid_lite_assets/data/robots/berkeley_humanoid/berkeley_humanoid_lite/mjcf/assets/leg_right_ankle_roll_visual.stl"/>

    <!-- 시각화 materials -->
    <material name="base_visual_material" rgba="0.67254 0.67254 0.67254 1"/>
    <material name="imu_2_visual_material" rgba="0.8 0.8 0.8 1"/>
    <material name="leg_left_hip_roll_visual_material" rgba="0.559597 0.559597 0.559597 1"/>
    <material name="leg_left_hip_yaw_visual_material" rgba="0.559547 0.559547 0.559547 1"/>
    <material name="leg_left_hip_pitch_visual_material" rgba="0.587522 0.587522 0.587522 1"/>
    <material name="leg_left_knee_pitch_visual_material" rgba="0.644721 0.644721 0.644721 1"/>
    <material name="leg_left_ankle_pitch_visual_material" rgba="0.743029 0.743029 0.743029 1"/>
    <material name="leg_left_ankle_roll_visual_material" rgba="0.664849 0.664849 0.664849 1"/>
    <material name="leg_right_hip_roll_visual_material" rgba="0.559597 0.559597 0.559597 1"/>
    <material name="leg_right_hip_yaw_visual_material" rgba="0.559547 0.559547 0.559547 1"/>
    <material name="leg_right_hip_pitch_visual_material" rgba="0.587522 0.587522 0.587522 1"/>
    <material name="leg_right_knee_pitch_visual_material" rgba="0.644721 0.644721 0.644721 1"/>
    <material name="leg_right_ankle_pitch_visual_material" rgba="0.743029 0.743029 0.743029 1"/>
    <material name="leg_right_ankle_roll_visual_material" rgba="0.664849 0.664849 0.664849 1"/>
    <material name="soarm_material" rgba="0.4 0.6 0.4 0.7"/>
  </asset>

  <!-- ── 월드 ────────────────────────────────────────────────── -->
  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane"
          contype="0" conaffinity="1" friction="0.8 0.1 0.1"
          material="matplane"/>

    <!-- ── BASE ─────────────────────────────────────────────── -->
    <body name="base" pos="0 0 0" quat="1 0 0 0" childclass="berkeley-humanoid-lite">
      <freejoint name="base_freejoint"/>

      <!-- base inertial: Hylion 학습 질량(4.83 kg), BHL CoM 위치 유지 -->
      <inertial pos="-0.00461671 0.000372279 0.637874"
                mass="4.83"
                fullinertia="0.0569 0.0432 0.0270 -6.2e-6 -0.00110 -2.3e-5"/>

      <!-- IMU 센서 부착점 (BHL biped 기준) -->
      <body name="imu_2" pos="0.061722 0 0.68" quat="1 0 0 0">
        <inertial pos="0 0 0.0025" mass="0.00197704"
                  fullinertia="1.11441e-07 4.06118e-08 1.43815e-07 0 0 0"/>
        <geom type="mesh" class="visual" pos="0 0 0.0025" quat="1 0 0 0"
              mesh="imu_2_visual" material="imu_2_visual_material"/>
        <site group="3" name="imu" pos="0 0 0.005" quat="1 0 0 0"/>
      </body>

      <!-- base visual mesh -->
      <geom type="mesh" class="visual"
            pos="-0.00461671 0.000372279 0.637874" quat="1 0 0 0"
            mesh="base_visual" material="base_visual_material"/>
      <!-- base collision box -->
      <geom class="collision"
            pos="0 0 0.71" quat="0.707107 0 0 -0.707107"
            type="box" size="0.075 0.07 0.115"/>

      <!-- ── SO-ARM 팔 (static, 관절 없음, 질량만) ──────────── -->
      <!-- Hylion 학습: SO-ARM101 × 2 = 6.88 kg, y=±0.12m 부착 -->
      <body name="soarm_left" pos="0.0 0.12 0.75">
        <inertial pos="0 0 -0.1" mass="3.44" diaginertia="0.025 0.025 0.005"/>
        <geom type="sphere" size="0.04" contype="0" conaffinity="0"
              material="soarm_material"/>
      </body>
      <body name="soarm_right" pos="0.0 -0.12 0.75">
        <inertial pos="0 0 -0.1" mass="3.44" diaginertia="0.025 0.025 0.005"/>
        <geom type="sphere" size="0.04" contype="0" conaffinity="0"
              material="soarm_material"/>
      </body>

      <!-- ── LEFT LEG (BHL biped 완전 동일) ───────────────────── -->
      <body name="leg_left_hip_roll" pos="-0.0290919 0.08 0.542631"
            quat="0.92388 0 0.382683 0">
        <joint axis="0 0 1" name="leg_left_hip_roll_joint" type="hinge"
               range="-0.17453292519942673 1.5707963267949028"/>
        <inertial pos="-0.00410941 -0.000112596 -0.0464623" mass="0.83786"
