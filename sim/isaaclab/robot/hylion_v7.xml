                       range="-0.7853981633975149 0.7853981633973817"/>
                <inertial pos="0.0131065 0.0273743 -0.0274153" mass="0.106196"
                          fullinertia="0.000188241 0.000142962 8.17203e-05 -2.50802e-05 7.26754e-06 7.72962e-06"/>
                <geom type="mesh" class="visual"
                      pos="0.0131065 0.0273743 -0.0274153"
                      quat="0.707107 0.707107 0 0"
