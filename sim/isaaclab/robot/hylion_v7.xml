        </body><!-- leg_right_hip_yaw -->
      </body><!-- leg_right_hip_roll -->

    </body><!-- base -->
  </worldbody>

  <!-- ── Actuator ────────────────────────────────────────────── -->
  <!-- play_mujoco.py에서 PD 계산 후 ctrl[i] = torque 방식 -->
  <actuator>
    <motor name="leg_left_hip_roll_joint"    joint="leg_left_hip_roll_joint"    forcerange="-20 20"/>
    <motor name="leg_left_hip_yaw_joint"     joint="leg_left_hip_yaw_joint"     forcerange="-20 20"/>
    <motor name="leg_left_hip_pitch_joint"   joint="leg_left_hip_pitch_joint"   forcerange="-20 20"/>
    <motor name="leg_left_knee_pitch_joint"  joint="leg_left_knee_pitch_joint"  forcerange="-20 20"/>
    <motor name="leg_left_ankle_pitch_joint" joint="leg_left_ankle_pitch_joint" forcerange="-20 20"/>
    <motor name="leg_left_ankle_roll_joint"  joint="leg_left_ankle_roll_joint"  forcerange="-20 20"/>
    <motor name="leg_right_hip_roll_joint"   joint="leg_right_hip_roll_joint"   forcerange="-20 20"/>
    <motor name="leg_right_hip_yaw_joint"    joint="leg_right_hip_yaw_joint"    forcerange="-20 20"/>
    <motor name="leg_right_hip_pitch_joint"  joint="leg_right_hip_pitch_joint"  forcerange="-20 20"/>
    <motor name="leg_right_knee_pitch_joint" joint="leg_right_knee_pitch_joint" forcerange="-20 20"/>
    <motor name="leg_right_ankle_pitch_joint" joint="leg_right_ankle_pitch_joint" forcerange="-20 20"/>
    <motor name="leg_right_ankle_roll_joint" joint="leg_right_ankle_roll_joint" forcerange="-20 20"/>
  </actuator>

  <!-- ── Sensor ──────────────────────────────────────────────── -->
  <sensor>
    <framequat name="imu_quat" objtype="site" objname="imu"/>
    <gyro      name="imu_gyro" site="imu"/>
    <framepos  name="frame_pos" objtype="site" objname="imu"/>
  </sensor>

</mujoco>
