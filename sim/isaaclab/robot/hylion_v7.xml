                  <geom type="mesh" class="visual"
                        pos="2.29341e-05 0.0226611 0.0197836"
                        quat="0.5 0.5 -0.5 0.5"
                        mesh="leg_left_ankle_roll_visual" material="leg_left_ankle_roll_visual_material"/>
                </body><!-- leg_left_ankle_roll -->
              </body><!-- leg_left_ankle_pitch -->
            </body><!-- leg_left_knee_pitch -->
          </body><!-- leg_left_hip_pitch -->
        </body><!-- leg_left_hip_yaw -->
      </body><!-- leg_left_hip_roll -->

      <!-- ── RIGHT LEG (BHL biped 완전 동일) ──────────────────── -->
